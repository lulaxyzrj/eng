{
    "kind": "minio",
    "description": "Local MinIO S3-compatible storage for development",
    "config": {
        "kind": "s3",
        "connectionConfigs": {
            "region": "us-east-1",
            "bucket": "shadowtraffic-data",
            "endpoint": "http://localhost:9000",
            "accessKey": "minioadmin",
            "secretKey": "minioadmin",
            "pathStyleAccess": true
        },
        "batchConfigs": {
            "lingerMs": 2000,
            "batchElements": 10000,
            "batchBytes": 5242880
        }
    }
}